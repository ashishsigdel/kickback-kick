# Copy to .env and edit. Loaded by mock_server.py via python-dotenv.

# How long one fake agentic run keeps producing output before it ends cleanly.
# Accepts: 30s, 5m, 1h, a bare number of seconds (90), or `unlimited`.
# The budget is tracked per agentic session, not per HTTP request, so a
# multi-turn tool loop stays inside the same budget.
FAKE_DURATION=unlimited

# Delay between streamed text deltas, in milliseconds.
CHUNK_DELAY_MS=40

# Pause between simulated agentic turns, in milliseconds.
TURN_DELAY_MS=500

# Random "thinking" pause before each response, in milliseconds. The server
# picks a fresh value in this range every time, so output arrives in paced
# bursts (wait -> response -> wait -> response) instead of one long firehose.
# Set both to 0 to stream continuously.
THINK_MIN_MS=5000
THINK_MAX_MS=7000

# Restart a script from the top when it runs out of segments. Set to false to
# end the turn cleanly once a transcript finishes — the only thing that stops
# the stream when FAKE_DURATION=unlimited.
SCRIPT_LOOP=false

# Dump every request body to logs/ as timestamped JSON. Off by default and best
# left that way for anything long-running: the CLI resends the whole transcript
# each turn, so bodies grow past a megabyte and there is one file per request.
# Turn it on to inspect what the CLI actually sends, then turn it back off.
FAKE_LOG_BODIES=0

# Where the mock server listens.
HOST=127.0.0.1
PORT=8787
