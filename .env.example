# Copy to .env and edit. Read by mock_server.py and by the keypress drivers.
# Environment variables override anything set here. Full notes in README.md.

# --- Server ------------------------------------------------------------------

# 30s, 5m, 1h, a bare number of seconds, or `unlimited`.
FAKE_DURATION=unlimited

# Milliseconds between streamed text deltas, and between agentic turns.
CHUNK_DELAY_MS=40
TURN_DELAY_MS=500

# Random "thinking" pause before each response, in milliseconds. 0/0 streams
# continuously.
THINK_MIN_MS=5000
THINK_MAX_MS=7000

# Restart a script from the top when it runs out of segments.
SCRIPT_LOOP=false

# Dump every request body to logs/. Heavy — leave off for long runs.
FAKE_LOG_BODIES=0

HOST=127.0.0.1
PORT=8787

# --- Driver pacing (keypress.sh, cloud/keypress-linux.sh) --------------------
# Ranges, redrawn on every use. Set both ends equal to pin one.

# Gap between typed characters, in milliseconds. ~110 WPM average.
KEYS_TYPE_MIN_MS=30
KEYS_TYPE_MAX_MS=190

# Multiplier on that range, drawn once per prompt so prompts differ from each
# other, not just character to character. 1/1 turns it off.
KEYS_TYPE_SPEED_MIN=0.7
KEYS_TYPE_SPEED_MAX=1.4

# Hesitation after a space or punctuation: chance (0-1) and length in seconds.
# Chance 0 turns it off.
KEYS_PAUSE_CHANCE=0.12
KEYS_PAUSE_MIN_SECS=0.3
KEYS_PAUSE_MAX_SECS=1.4

# Typing finished -> Enter pressed, in seconds.
KEYS_ENTER_MIN_SECS=0.4
KEYS_ENTER_MAX_SECS=2.5

# Turn finished -> next prompt typed, in seconds.
KEYS_READ_MIN_SECS=3
KEYS_READ_MAX_SECS=8

# End of the prompt list -> restart from the top, in seconds.
KEYS_CYCLE_PAUSE_MIN_SECS=2
KEYS_CYCLE_PAUSE_MAX_SECS=15
